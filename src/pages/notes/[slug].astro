---
import BaseLayout from '../../layouts/BaseLayout.astro';
import pagesRaw from '../../generated/pages.json';

interface PublicPage {
  title: string;
  slug: string;
  kind: 'note' | 'topic' | 'index';
  topics: string[];
  image: string | null;
  imageAlt: string | null;
  imageCaption: string | null;
  bodyHtml: string;
  backlinks: string[];
}
const pages = pagesRaw as PublicPage[];
export function getStaticPaths() {
  const staticNotes = (pagesRaw as PublicPage[]).filter((page) => page.kind === 'note');
  return staticNotes.map((note) => ({ params: { slug: note.slug }, props: { note } }));
}

const { note } = Astro.props as { note: PublicPage };
const backlinks = note.backlinks
  .map((slug) => pages.find((page) => page.slug === slug))
  .filter((page): page is PublicPage => Boolean(page));
---
<BaseLayout title={`${note.title} — Rock from Space Demo`}>
  <article class="article">
    <header class="article-header">
      <p class="kicker">Note</p>
      <h1>{note.title}</h1>
      {note.topics.length > 0 && <p class="article-topics">{note.topics.join(', ')}</p>}
    </header>
    {note.image && (
      <figure class="article-image">
        <img src={note.image} alt={note.imageAlt ?? note.title} loading="lazy" decoding="async" />
        {note.imageCaption && <figcaption>{note.imageCaption}</figcaption>}
      </figure>
    )}
    <div class="article-body" set:html={note.bodyHtml} />
    {backlinks.length > 0 && (
      <section class="article-related">
        <h2>Related</h2>
        <ul>
          {backlinks.map((backlink) => <li><a href={`/notes/${backlink.slug}/`}>{backlink.title}</a></li>)}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>
