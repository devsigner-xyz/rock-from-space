---
import BaseLayout from '../../layouts/BaseLayout.astro';
import pagesRaw from '../../generated/pages.json';

interface PageIndexItem { title: string; slug: string; kind: 'note' | 'topic' | 'index'; topics: string[]; }
const notes = (pagesRaw as PageIndexItem[]).filter((page) => page.kind === 'note');
---
<BaseLayout title="Notes — Rock from Space Demo">
  <section class="hero">
    <p class="kicker">Public export</p>
    <h1>Notes</h1>
    <p>All public notes generated from the exported Markdown content.</p>
  </section>

  <div class="grid">
    {notes.map((note) => (
      <a class="card" href={`/notes/${note.slug}/`}>
        <strong>{note.title}</strong>
        <p>{note.topics.join(', ') || 'No topics'}</p>
      </a>
    ))}
  </div>
</BaseLayout>
