{
  "site": {
    "title": "Rock from Space Demo",
    "description": "An Obsidian-compatible Markdown vault rendered with Astro.",
    "language": "en",
    "url": "https://example.com",
    "base": "/"
  },
  "vault": {
    "path": "examples/demo-vault",
    "mode": "managed",
    "allow": [
      "index.md",
      "Notes/**",
      "Topics/**"
    ],
    "ignore": [
      ".obsidian/**",
      "**/Private/**"
    ]
  },
  "publish": {
    "requireField": "publish",
    "requireValue": true,
    "output": "content"
  },
  "routes": {
    "notes": "/notes",
    "topics": "/topics"
  },
  "collections": [
    {
      "name": "notes",
      "source": "Notes/**",
      "route": "/notes",
      "template": "note",
      "schema": {
        "required": ["title", "publish"],
        "optional": ["topics"]
      }
    }
  ],
  "taxonomies": [
    {
      "name": "topics",
      "field": "topics",
      "route": "/topics",
      "source": "Topics/**",
      "template": "topic"
    }
  ],
  "privacy": {
    "forbiddenPatterns": [
      "/home/",
      "password",
      "secret",
      "api_key",
      "token"
    ],
    "blockedFrontmatterFields": [
      "private",
      "secret",
      "internal"
    ],
    "allowedEmbedDomains": []
  },
  "deploy": {
    "target": "static",
    "output": "dist",
    "predeploy": [
      "content:export",
      "content:index",
      "audit:content",
      "build"
    ]
  },
  "agent": {
    "skillsPath": "agent/skills",
    "promptsPath": "agent/prompts",
    "checklistsPath": "agent/checklists"
  }
}
